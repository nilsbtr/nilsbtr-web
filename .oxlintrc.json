{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "options": {
    "typeAware": false
  },
  "plugins": ["eslint", "typescript", "unicorn", "react", "nextjs", "jsx-a11y"],
  "env": {
    "node": true,
    "browser": true,
    "es2022": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "warn"
  },
  "rules": {
    "no-console": "warn",
    "react/no-unknown-property": "off",
    "react/react-in-jsx-scope": "off",
    "react/prop-types": "off",
    "react/jsx-no-target-blank": "off",
    "import/no-unassigned-import": [
      "warn",
      {
        "allow": ["**/*.css"]
      }
    ],
    "eslint/max-lines-per-function": "off",
    "eslint/max-lines": "off"
  },
  "ignorePatterns": [
    ".next/**",
    "node_modules/**",
    "out/**",
    "build/**",
    "coverage/**",
    "next-env.d.ts"
  ]
}
